# NO-BACKEND VERSION - Environment Variables
# Copy this file to .env.local and fill in the values

# ========================================
# REQUIRED: Google Translate API Key
# ========================================
# This is the ONLY required variable for NO-BACKEND version
# Get your free key from: https://cloud.google.com
# 
# Steps:
# 1. Visit https://cloud.google.com
# 2. Sign up (includes $300 free credit)
# 3. Go to APIs & Services > Library
# 4. Search for "Google Translate API"
# 5. Click "Enable"
# 6. Go to Credentials > Create API Key
# 7. Copy the key here (should start with "AIzaSy")
#
# Free tier: 500,000 characters/month
VITE_GOOGLE_TRANSLATE_API_KEY=paste-your-key-here
# Enable: Google Translate API
# Create: API Key
VITE_GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key-here

# Node environment
# NODE_ENV=development
